{
  "functions": {
    "app/api/assessment/submit/route.ts": {
      "maxDuration": 60
    },
    "app/api/reports/*/route.ts": {
      "maxDuration": 60
    },
    "app/api/scrape/*/route.ts": {
      "maxDuration": 45
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/lead-score",
      "destination": "/assessments/lead-score"
    },
    {
      "source": "/pipeline-audit", 
      "destination": "/assessments/pipeline-leak"
    },
    {
      "source": "/proposal-generator",
      "destination": "/assessments/proposal"
    },
    {
      "source": "/tech-audit",
      "destination": "/assessments/tech-audit"
    }
  ]
}
{
  "name": "maru-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "db:push:website": "DATABASE_TARGET=website npx drizzle-kit push --force",
    "db:push:lead-engine": "DATABASE_TARGET=lead_engine npx drizzle-kit push --force",
    "db:push:all": "npm run db:push:website && npm run db:push:lead-engine",
    "db:studio:website": "DATABASE_TARGET=website npx drizzle-kit studio",
    "db:studio:lead-engine": "DATABASE_TARGET=lead_engine npx drizzle-kit studio",
    "db:generate:website": "DATABASE_TARGET=website npx drizzle-kit generate",
    "db:generate:lead-engine": "DATABASE_TARGET=lead_engine npx drizzle-kit generate"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@mendable/firecrawl-js": "^4.10.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sanity/image-url": "^2.0.2",
    "@sanity/vision": "^5.2.0",
    "@supabase/supabase-js": "^2.89.0",
    "@vercel/analytics": "^1.6.1",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.23.25",
    "jose": "^6.1.3",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.460.0",
    "next": "^16.0.6",
    "next-sanity": "^12.0.9",
    "nodemailer": "^7.0.12",
    "react": "^19.2.0",
    "react-calendly": "^4.4.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "resend": "^4.0.1",
    "sanity": "^5.2.0",
    "styled-components": "^6.2.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.0.0-beta.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0-beta.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
